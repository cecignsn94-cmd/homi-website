---
<footer class="footer">
  <div class="container footer-content">
    <a href="/" class="logo">
      <span class="logo-text">HOMI</span>
      <span class="logo-dot"></span>
    </a>
    <p class="copyright">HOMI 2019 - 2026</p>
    <div class="footer-links">
      <a href="#servicios">Servicios</a>
      <a href="#como-funciona">Proceso</a>
      <a href="https://wa.me/523331992043?text=Me%20interesa%20reservar%20un%20servicio%20de%20lavado" target="_blank" rel="noopener noreferrer">Contacto</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 6rem 0 4rem;
    background: var(--surface);
    border-top: 1px solid var(--glass-border);
    margin-top: 4rem;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 2px;
  }

  .logo-dot {
    width: 8px;
    height: 8px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--primary);
  }

  .copyright {
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .footer-links {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
