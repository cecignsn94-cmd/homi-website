---
---
<section class="car-scroll-track" id="car-section">
  <!-- El Túnel de Lavado de Coches -->
  <div class="car-wash-stage" id="wash-stage">
    
    <!-- Cepillo 1: Rodillo de Enjabonado -->
    <div class="brush soap-brush"></div>
    
    <!-- Cepillo 2: Rodillo de Secado y Encerado -->
    <div class="brush water-brush"></div>

  </div>

  <div class="car-track">
    <!-- Vehículo Real -->
    <div class="car-wrapper" id="car-vehicle">
      <!-- Vehículo Rojo de Caricatura -->
      <img class="real-car" src="/images/car-red-cartoon.png" alt="Coche" />
      
      <!-- Efecto de espuma real pegada a la carrocería -->
      <div class="foam-overlay" id="car-foam"></div>
      
      <svg class="organic-sparkle s1" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.4 7.6H22l-6.2 4.5 2.4 7.6-6.2-4.5-6.2 4.5 2.4-7.6L2 9.6h7.6z"/></svg>
      <svg class="organic-sparkle s2" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.4 7.6H22l-6.2 4.5 2.4 7.6-6.2-4.5-6.2 4.5 2.4-7.6L2 9.6h7.6z"/></svg>
    </div>
  </div>
</section>

<script>
  const section = document.getElementById('car-section');
  const car = document.getElementById('car-vehicle');
  const foam = document.getElementById('car-foam');
  const stage = document.getElementById('wash-stage');
  
  let ticking = false;

  const runCarAnimation = () => {
    if (!section || !car || !foam || !stage) return;
    
    const rect = section.getBoundingClientRect();
    const windowHeight = window.innerHeight;
    
    if (rect.top < windowHeight && rect.bottom > 0) {
      const totalScroll = windowHeight + rect.height;
      const currentScroll = windowHeight - rect.top;
      let progress = currentScroll / totalScroll;
      progress = Math.max(0, Math.min(1, progress));
      
      const moveX = (progress * (window.innerWidth + 400)) - 260; 

      car.style.transform = `translate3d(${moveX}px, -50%, 0)`;

      // Geometría virtual del túnel de lavado
      const soapPos = window.innerWidth * 0.35; // Posición Rodillo 1
      const waterPos = window.innerWidth * 0.65; // Posición Rodillo 2
      
      const carFront = moveX + 260; // Frente del auto
      const carCenter = moveX + 130;
      const carBack = moveX;

      // 1. Enjabonado progresivo
      if (carFront > soapPos && carCenter < waterPos) {
        let soapAmount = (carFront - soapPos) / 200; 
        foam.style.opacity = Math.min(0.9, Math.max(0, soapAmount)).toString();
      } 
      // 2. Enjuague limpio
      else if (carCenter >= waterPos) {
        let washAmount = 0.9 - ((carCenter - waterPos) / 100);
        foam.style.opacity = Math.min(0.9, Math.max(0, washAmount)).toString();
      } else {
        foam.style.opacity = '0';
      }

      // 3. Destello y brillo al salir
      if (carBack > waterPos) {
        car.classList.add('clean');
      } else {
        car.classList.remove('clean');
      }
      
      // Animación súper inmersiva de rodillos girando al scrollear
      const brushes = document.querySelectorAll('.brush');
      brushes.forEach(b => {
         // El desplazamiento del fondo imita la rotación de un rodillo
         b.style.backgroundPosition = `0px ${progress * 1500}px`;
      });
    }
    
    ticking = false;
  };

  document.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(runCarAnimation);
      ticking = true;
    }
  }, { passive: true });
</script>

<style>
  .car-scroll-track {
    position: relative;
    width: 100%;
    height: 200px;
    background: transparent;
    overflow: hidden;
    margin: 3rem 0;
    pointer-events: none;
  }

  /* Infraestructura de túnel físico */
  .car-wash-stage {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
  }

  /* Los icónicos rodillos giratorios de lavado */
  .brush {
    position: absolute;
    top: 10px;
    bottom: 10px;
    width: 60px;
    border-radius: 30px;
    box-shadow: 
      inset -15px 0 20px rgba(0,0,0,0.6), 
      inset 5px 0 10px rgba(255,255,255,0.4),
      0 0 25px rgba(0,0,0,0.3);
    z-index: 10; /* Tapan al auto, creando profundidad en 3D */
    will-change: background-position;
  }

  /* Rodillo 1: Esponjas azules de champú */
  .soap-brush {
    left: 35%;
    transform: translateX(-50%);
    background: repeating-linear-gradient(20deg, #0ea5e9, #0ea5e9 20px, #0284c7 20px, #0284c7 40px);
  }

  /* Rodillo 2: Bandas grises de secado/encerado */
  .water-brush {
    left: 65%;
    transform: translateX(-50%);
    background: repeating-linear-gradient(-20deg, #cbd5e1, #cbd5e1 20px, #94a3b8 20px, #94a3b8 40px);
  }

  .car-track {
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    z-index: 5;
  }

  .car-wrapper {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate3d(-300px, -50%, 0);
    will-change: transform, filter; 
    transition: filter 0.5s ease-out;
    filter: sepia(0.5) brightness(0.7) opacity(0.85); /* Llega sucio */
  }

  .real-car {
    display: block;
    width: 260px;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  /* La espuma blanca esponjosa y realista saturando el auto */
  .foam-overlay {
    position: absolute;
    top: 20px; left: 20px; right: 20px; bottom: 20px;
    background-image: 
      radial-gradient(circle at 30% 50%, rgba(255,255,255,0.95) 15%, transparent 25%),
      radial-gradient(circle at 60% 40%, rgba(255,255,255,0.9) 20%, transparent 35%),
      radial-gradient(circle at 45% 70%, rgba(255,255,255,0.95) 20%, transparent 30%),
      radial-gradient(circle at 80% 60%, rgba(255,255,255,0.9) 15%, transparent 25%);
    background-size: 100% 100%;
    filter: blur(4px);
    opacity: 0;
    will-change: opacity;
    mix-blend-mode: screen; /* Permite ver ligeros detalles debajo */
  }

  /* Deslumbramiento post-lavado */
  .car-wrapper.clean {
    filter: sepia(0) brightness(1.2) opacity(1) drop-shadow(0 10px 20px rgba(8, 145, 178, 0.4));
  }

  .organic-sparkle {
    position: absolute;
    width: 30px;
    height: 30px;
    color: var(--primary);
    opacity: 0;
    transform: scale(0) rotate(0deg);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .car-wrapper.clean .organic-sparkle {
    opacity: 1;
    transform: scale(1) rotate(45deg);
  }

  .s1 { top: -10px; right: 20px; width: 40px; height: 40px; }
  .s2 { bottom: 0px; left: 30px; animation-delay: 0.1s; }
</style>
