---
<div class="bubbles-container">
  <div class="bubble-wrapper x1"><div class="bubble"></div></div>
  <div class="bubble-wrapper x2"><div class="bubble"></div></div>
  <div class="bubble-wrapper x3"><div class="bubble"></div></div>
  <div class="bubble-wrapper x4"><div class="bubble"></div></div>
  <div class="bubble-wrapper x5"><div class="bubble"></div></div>
  <div class="bubble-wrapper x6"><div class="bubble"></div></div>
  <div class="bubble-wrapper x7"><div class="bubble"></div></div>
  <div class="bubble-wrapper x8"><div class="bubble"></div></div>
  <div class="bubble-wrapper x9"><div class="bubble"></div></div>
  <div class="bubble-wrapper x10"><div class="bubble"></div></div>
  <div class="bubble-wrapper x11"><div class="bubble"></div></div>
  <div class="bubble-wrapper x12"><div class="bubble"></div></div>
</div>

<script>
  // DOM Cache & Performance Optimizations
  const wrappers = document.querySelectorAll('.bubble-wrapper');
  let ticking = false;

  const handleAnimation = () => {
    const scrollY = window.scrollY;
    
    if (scrollY > 100) {
      wrappers.forEach((wrapper, index) => {
        if (!wrapper.classList.contains('pop')) {
          setTimeout(() => {
            if (window.scrollY > 100) wrapper.classList.add('pop');
          }, Math.random() * 600 + (index * 40));
        }
      });
    } else if (scrollY < 20) {
      wrappers.forEach((wrapper) => {
        if (wrapper.classList.contains('pop')) {
          setTimeout(() => {
            if (window.scrollY < 20) wrapper.classList.remove('pop');
          }, Math.random() * 400);
        }
      });
    }
    ticking = false;
  };

  document.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(handleAnimation);
      ticking = true;
    }
  }, { passive: true });
</script>

<style>
.bubbles-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  overflow: hidden;
  pointer-events: none;
}

.bubble-wrapper {
  position: absolute;
  bottom: -100px;
  animation: fly 10s infinite ease-in;
  will-change: transform;
}

.bubble {
  width: 100%;
  height: 100%;
  background: rgba(8, 145, 178, 0.05);
  border: 1px solid rgba(8, 145, 178, 0.2);
  border-radius: 50%;
  box-shadow: inset 0 0 10px rgba(8, 145, 178, 0.1);
  transform-origin: center center;
  will-change: transform, opacity;
}

.bubble-wrapper.pop .bubble {
  animation: popEffect 0.3s ease-out forwards;
}

.x1 { left: 10%; width: 40px; height: 40px; animation-duration: 8s; }
.x2 { left: 20%; width: 20px; height: 20px; animation-duration: 5s; animation-delay: 1s; }
.x3 { left: 30%; width: 50px; height: 50px; animation-duration: 7s; animation-delay: 2s; }
.x4 { left: 40%; width: 30px; height: 30px; animation-duration: 6s; animation-delay: 0.5s; }
.x5 { left: 50%; width: 60px; height: 60px; animation-duration: 9s; animation-delay: 3s; }
.x6 { left: 60%; width: 25px; height: 25px; animation-duration: 4s; animation-delay: 1.5s; }
.x7 { left: 70%; width: 45px; height: 45px; animation-duration: 8s; animation-delay: 4s; }
.x8 { left: 80%; width: 35px; height: 35px; animation-duration: 6s; animation-delay: 2.5s; }
.x9 { left: 90%; width: 55px; height: 55px; animation-duration: 9s; animation-delay: 0.2s; }
.x10 { left: 95%; width: 20px; height: 20px; animation-duration: 5s; animation-delay: 3.5s; }
.x11 { left: 5%; width: 70px; height: 70px; animation-duration: 11s; animation-delay: 1.2s; }
.x12 { left: 85%; width: 15px; height: 15px; animation-duration: 4.5s; animation-delay: 0.8s; }

@keyframes fly {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 1; }
  50% { transform: translateY(-55vh) translateX(25px); }
  90% { opacity: 1; }
  100% { transform: translateY(-110vh) translateX(-25px); opacity: 0; }
}

@keyframes popEffect {
  0% { transform: scale(1); opacity: 1; }
  40% { transform: scale(1.4); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}
</style>
