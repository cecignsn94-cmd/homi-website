---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const benefits = [
  {
    title: "Mantenimiento Continuo",
    description:
      "Visitas programadas cada semana para que tu coche nunca pierda su brillo.",
    icon: "🗓️",
  },
  {
    title: "Prioridad VIP",
    description:
      "Acceso exclusivo a horarios premium y atención prioritaria vía WhatsApp.",
    icon: "⭐",
  },
  {
    title: "Precio preferencial",
    description:
      "Ahorra hasta un 20% comparado con servicios individuales contratados por separado.",
    icon: "💰",
  },
];

const plans = [
  {
    name: "Homi Pro",
    prices: [
      { label: "Ch", amount: "$640", emoji: "🚗" },
      { label: "Med", amount: "$800", emoji: "🚙" },
      { label: "Gde", amount: "$930", emoji: "🛻" },
      { label: "ExtGde", amount: "$1,100", emoji: "🚐" },
    ],
    period: "/mes",
    description: "Nuestro plan más balanceado y popular.",
    features: [
      "4 Lavados Completos (1 por semana)",
      "Aspirado profundo",
      "1 Encerado líquido (1 por mes)",
      "Atención prioritaria",
    ],
    popular: true,
  },
  {
    name: "Homi Basic",
    prices: [
      { label: "Ch", amount: "$480", emoji: "🚗" },
      { label: "Med", amount: "$600", emoji: "🚙" },
      { label: "Gde", amount: "$760", emoji: "🛻" },
      { label: "ExtGde", amount: "$880", emoji: "🚐" },
    ],
    period: "/mes",
    description: "Ideal para mantener el exterior impecable.",
    features: [
      "4 Lavados Exteriores (1 por semana)",
      "Limpieza de rines",
      "Atención prioritaria",
    ],
    popular: false,
  },
  {
    name: "Homi Mixto",
    prices: [
      { label: "Ch", amount: "$560", emoji: "🚗" },
      { label: "Med", amount: "$700", emoji: "🚙" },
      { label: "Gde", amount: "$840", emoji: "🛻" },
      { label: "ExtGde", amount: "$950", emoji: "🚐" },
    ],
    period: "/mes",
    description: "La combinación perfecta entre mantenimiento y limpieza profunda.",
    features: [
      "4 Lavados (1 por semana):",
      "2 Lavados Exteriores",
      "2 Lavados Completos (exterior y aspirado)",
      "Atención prioritaria",
    ],
    popular: false,
  },
];
---

<Layout title="Homi Club | Membresía Exclusiva de Lavado">
  <Navbar />
  <main>
    <section class="club-hero">
      <div class="container hero-content animate-fade-in">
        <h2 style="font-size: clamp(2.25rem, 8vw, 4rem); font-weight: 800; color: var(--text); margin: 0 auto 1.5rem auto; line-height: 1.1; max-width: 900px; text-wrap: balance;">Lavado de coches en la comodidad de tu casa</h2>
        <div class="club-badge-large">Membresía Exclusiva</div>
        <h1>Únete a <span class="text-gradient">Homi Club</span></h1>
        <p>
          En Homi llevamos el lavado de coches profesional directamente a tu domicilio. Únete a nuestro club exclusivo y descubre la forma más inteligente de mantener el valor y la estética de tu vehículo sin mover un solo dedo.
        </p>
      </div>
    </section>

    <section class="pricing container">
      <div class="pricing-header">
        <h2 class="section-title">Nuestros Planes</h2>
        <p>Elige el plan que mejor se adapte a tus necesidades de cuidado.</p>
      </div>
      <div class="carousel-wrapper">
        <button class="carousel-arrow prev-arrow" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="pricing-grid" id="pricingGrid">
          {
          plans.map((plan) => (
            <div
              class={`glass-card plan-card ${plan.popular ? "popular" : ""}`}
            >
              {plan.popular && <div class="most-popular">Más Recomendado</div>}
              <div class="plan-header">
                <h3>{plan.name}</h3>
                <div class="prices-container">
                  {plan.prices.map((p) => (
                    <a href={`https://wa.me/523319118971?text=${encodeURIComponent(`Me interesa suscribirme al plan ${plan.name} para un auto ${p.label} (${p.amount})`)}`} target="_blank" rel="noopener noreferrer" class="price-row">
                      <span class="price-emoji">{p.emoji} {p.label}</span>
                      <div class="price-value-container">
                        <span class="price-amount">{p.amount}</span>
                        <span class="price-period">{plan.period}</span>
                      </div>
                    </a>
                  ))}
                </div>
                <p>{plan.description}</p>
              </div>
              <ul class="plan-features">
                {plan.features.map((feature) => (
                  <li class={feature.endsWith(":") ? "feature-title" : ""}>
                    {!feature.endsWith(":") && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="check-icon"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    )}
                    {feature}
                  </li>
                ))}
              </ul>
              <a
                href={`https://wa.me/523319118971?text=Me%20interesa%20unirme%20al%20Homi%20Club%20con%20el%20plan%20${encodeURIComponent(
                  plan.name
                )}`}
                target="_blank"
                rel="noopener noreferrer"
                class={`btn ${
                  plan.popular ? "btn-primary" : "btn-secondary-outline"
                }`}
              >
                Elegir Plan
              </a>
            </div>
          ))
        }
        </div>
        <button class="carousel-arrow next-arrow" aria-label="Siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </section>

    <section class="benefits container">
      <h2 class="section-title" style="text-align: center; margin-bottom: 3rem;">Beneficios de Homi Club</h2>
      <div class="benefits-grid">
        {
          benefits.map((benefit) => (
            <div class="glass-card benefit-item">
              <span class="benefit-icon">{benefit.icon}</span>
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="cta-bottom container">
      <div class="glass-card cta-box">
        <h2>¿Tienes varios vehículos?</h2>
        <p>
          Ofrecemos descuentos especiales para flotillas o empresas.
          Consúltanos por WhatsApp.
        </p>
        <a
          href="https://wa.me/523319118971?text=Me%20interesa%20un%20plan%20para%20varios%20veh%C3%ADculos"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary">Hablar con un asesor</a
        >
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('pricingGrid');
    const prevBtn = document.querySelector('.prev-arrow') as HTMLButtonElement | null;
    const nextBtn = document.querySelector('.next-arrow') as HTMLButtonElement | null;

    if (grid && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        grid.scrollBy({ left: -window.innerWidth * 0.8, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        grid.scrollBy({ left: window.innerWidth * 0.8, behavior: 'smooth' });
      });
      
      const updateButtons = () => {
        if (grid.scrollLeft <= 5) {
          prevBtn.style.opacity = '0.3';
          prevBtn.style.pointerEvents = 'none';
        } else {
          prevBtn.style.opacity = '1';
          prevBtn.style.pointerEvents = 'auto';
        }
        
        if (grid.scrollLeft >= (grid.scrollWidth - grid.clientWidth - 5)) {
          nextBtn.style.opacity = '0.3';
          nextBtn.style.pointerEvents = 'none';
        } else {
          nextBtn.style.opacity = '1';
          nextBtn.style.pointerEvents = 'auto';
        }
      };
      
      grid.addEventListener('scroll', updateButtons);
      window.addEventListener('resize', updateButtons);
      setTimeout(updateButtons, 100);
    }
  });
</script>

<style>
  main {
    padding-top: 70px;
  }

  .club-hero {
    padding: clamp(4rem, 15vh, 8rem) 1rem 4rem;
    text-align: center;
  }

  .club-badge-large {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px var(--primary-glow);
  }

  .club-hero h1 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .club-hero p {
    font-size: clamp(1rem, 3vw, 1.2rem);
    color: var(--text-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .benefits {
    padding-bottom: 6rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .benefit-item {
    text-align: center;
    transition: all 0.3s ease;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .benefit-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1.5rem;
  }

  .benefit-item h3 {
    margin-bottom: 0.75rem;
    font-size: 1.35rem;
  }

  /* Pricing Section */
  .pricing {
    padding: 6rem 1.5rem;
    background: rgba(8, 145, 178, 0.02);
    border-radius: clamp(30px, 10vw, 60px);
    max-width: 1216px;
    margin: 0 auto;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .pricing-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 1rem auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: 2rem;
    align-items: stretch;
  }

  .plan-card {
    display: flex;
    flex-direction: column;
    padding: 3rem 2rem;
    height: 100%;
    position: relative;
    border: 1px solid var(--glass-border);
  }

  .plan-card.popular {
    border-color: var(--primary);
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(8, 145, 178, 0.1);
  }

  .most-popular {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--primary);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 99px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .plan-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .plan-header h3 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .prices-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .price-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(8, 145, 178, 0.05);
    border: 1px solid rgba(8, 145, 178, 0.1);
    border-radius: 12px;
    padding: 0.5rem 0.5rem;
    gap: 0.25rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .price-row:hover {
    background: rgba(8, 145, 178, 0.15);
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(8, 145, 178, 0.1);
  }

  .price-value-container {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .price-emoji {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .price-amount {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }

  .price-period {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .plan-features {
    list-style: none;
    margin: 0 auto 3rem auto;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: fit-content;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    text-align: left;
  }

  .plan-features li.feature-title {
    color: var(--text);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .check-icon {
    flex-shrink: 0;
    color: var(--primary);
  }

  /* CTA Bottom */
  .cta-bottom {
    padding: 6rem 1.5rem 8rem;
  }

  .cta-box {
    text-align: center;
    padding: 4rem 1.5rem;
    background: linear-gradient(
      135deg,
      rgba(8, 145, 178, 0.05) 0%,
      rgba(255, 255, 255, 0.5) 100%
    );
  }

  .cta-box h2 {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .cta-box p {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.5;
  }

  .btn-secondary-outline {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text);
    justify-content: center;
    width: 100%;
  }

  .btn-secondary-outline:hover {
    background: var(--glass);
    border-color: var(--primary);
  }

  .btn-primary {
    justify-content: center;
    width: 100%;
  }

  .carousel-wrapper {
    position: relative;
  }

  .carousel-arrow {
    display: none;
  }

  @media (max-width: 768px) {
    .carousel-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 50%;
      z-index: 10;
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      cursor: pointer;
      transition: opacity 0.3s ease;
    }
    .prev-arrow {
      left: -0.5rem;
    }
    .next-arrow {
      right: -0.5rem;
    }

    .pricing-grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1rem;
      padding: 1rem 1.5rem 3rem 1.5rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      -webkit-overflow-scrolling: touch;
      scroll-padding-left: 1.5rem;
      scrollbar-width: none; /* Firefox */
    }

    .pricing-grid::-webkit-scrollbar {
      display: none; /* Safari and Chrome */
    }

    .plan-card {
      padding: 2.5rem 1.5rem;
      flex: 0 0 85%;
      min-width: 85%;
      max-width: 85%;
      scroll-snap-align: center;
    }

    .plan-card.popular {
      transform: none;
    }
  }

  @media (max-width: 480px) {
    .pricing {
      padding: 3rem 1rem;
    }
    .plan-header h3 {
      font-size: 1.5rem;
    }
    .price-amount {
      font-size: 1.5rem;
    }
  }
</style>
